{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WiVRn Mac Host",
  "version": "0.1.0",
  "identifier": "dev.xrremote.wivrn-macos-host",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "WiVRn Mac Host",
        "width": 860,
        "height": 680,
        "minWidth": 720,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "createUpdaterArtifacts": true,
    "externalBin": ["binaries/wivrn-server-headless"],
    "resources": {
      "resources/openxr/": "openxr/"
    },
    "macOS": {
      "minimumSystemVersion": "14.0"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/kzahel/wivrn-macos/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQxNUQzREY0QjNEMENGQjgKUldTNHo5Q3o5RDFkUWRwNnpxMTR2UnBiUFVGejlaYnpIU0t2bkJYanBTenBZMFR0a0J5WUU3SzIK"
    }
  }
}
